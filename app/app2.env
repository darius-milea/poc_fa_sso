PORT=3001
APP_NAME=SSO Demo App 2
CLIENT_ID=22222222-2222-2222-2222-222222222222
CLIENT_SECRET=app2-super-secret-change-me
# FusionAuth on its own registrable domain (all resolve to 127.0.0.1)
FUSIONAUTH_URL=http://auth.lacolhost.com:9011
SESSION_SECRET=app2-session-secret-change-me
# This app's own public host, and the other app's — genuinely cross-site
# (lvh.me vs localtest.me are different registrable domains).
BASE_URL=http://app2.lvh.me:3001
OTHER_APP_URL=http://app1.localtest.me:3000
# Auto-attempt silent SSO (prompt=none) on landing — no login button needed
AUTO_SSO=1
