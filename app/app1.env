PORT=3000
APP_NAME=SSO Demo App 1
CLIENT_ID=11111111-1111-1111-1111-111111111111
CLIENT_SECRET=app1-super-secret-change-me
# FusionAuth on its own registrable domain (all resolve to 127.0.0.1)
FUSIONAUTH_URL=http://auth.lacolhost.com:9011
SESSION_SECRET=app1-session-secret-change-me
# This app's own public host, and the other app's — genuinely cross-site
# (localtest.me vs lvh.me are different registrable domains).
BASE_URL=http://app1.localtest.me:3000
OTHER_APP_URL=http://app2.lvh.me:3001
# Show App 2 as an "open in new tab" button (top-level, first-party — works
# cross-domain). Set EMBED_MODE=iframe to see the iframe break cross-domain.
EMBED_APP_URL=http://app2.lvh.me:3001
EMBED_MODE=tab
