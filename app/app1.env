PORT=3000
APP_NAME=SSO Demo App 1
CLIENT_ID=11111111-1111-1111-1111-111111111111
CLIENT_SECRET=app1-super-secret-change-me
FUSIONAUTH_URL=http://localhost:9011
SESSION_SECRET=app1-session-secret-change-me
# When set, App 1 shows this second app. EMBED_MODE picks how:
#   iframe = embed in an <iframe> (breaks cross-domain: third-party cookies)
#   tab    = "open in new tab" button (top-level, first-party — works cross-domain)
EMBED_APP_URL=http://localhost:3001
EMBED_MODE=iframe
